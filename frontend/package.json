{
	"name": "frontend",
	"version": "0.1.2",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"desktop:build-sidecar": "uv run python ../scripts/build_sidecar.py",
		"tauri:dev": "tauri dev",
		"tauri:clean": "rm -rf src-tauri/target/release/bundle src-tauri/target/release/reports-desktop || true",
		"tauri:build": "tauri build",
		"tauri:build:mac": "bun run tauri:clean && bun run desktop:build-sidecar && tauri build --config src-tauri/tauri.macos.conf.json --bundles app && bash ../scripts/build_dmg.sh",
		"tauri:build:win": "bun run tauri:clean && bun run desktop:build-sidecar && tauri build --config src-tauri/tauri.windows.conf.json",
		"tauri:build:dmg": "bun run tauri:clean && bun run desktop:build-sidecar && bun run tauri:build"
	},
	"type": "module",
	"dependencies": {
		"@formkit/auto-animate": "^0.9.0",
		"@tauri-apps/api": "^2.0.0",
		"@tauri-apps/plugin-dialog": "^2.0.0",
		"@tauri-apps/plugin-opener": "^2.5.3",
		"animejs": "^4.3.6"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@internationalized/date": "^3.10.0",
		"@lucide/svelte": "^0.561.0",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-static": "^3.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@tauri-apps/cli": "^2.0.0",
		"@types/node": "^20",
		"@vitest/browser-playwright": "^4.0.18",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"publint": "^0.3.17",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwind-merge": "^3.4.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vitest": "^4.0.18",
		"vitest-browser-svelte": "^2.0.2"
	},
	"keywords": [
		"svelte"
	]
}
