{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Reports",
  "version": "0.1.2",
  "identifier": "com.rakinzisilver.reports",
  "build": {
    "beforeBuildCommand": "npm run desktop:build-sidecar && npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Reports",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "externalBin": [
      "binaries/reports-api"
    ]
  }
}
